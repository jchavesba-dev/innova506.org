rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function profilePath(uid) {
      return /databases/$(database)/documents/userProfiles/$(uid);
    }

    function hasProfile() {
      return signedIn() && exists(profilePath(request.auth.uid));
    }

    function currentProfile() {
      return get(profilePath(request.auth.uid)).data;
    }

    function isAdmin() {
      return hasProfile() && currentProfile().role == 'admin' && currentProfile().disabled != true;
    }

    function isTeacher() {
      return hasProfile() && currentProfile().role == 'teacher' && currentProfile().disabled != true;
    }

    function isStudent() {
      return hasProfile() && currentProfile().role == 'student' && currentProfile().disabled != true;
    }

    function enrollmentPath(courseId, uid) {
      return /databases/$(database)/documents/enrollments/$(courseId + '_' + uid);
    }

    function isCourseMember(courseId) {
      return hasProfile() && exists(enrollmentPath(courseId, request.auth.uid));
    }

    function isTeacherFor(courseId) {
      return isTeacher()
        && exists(enrollmentPath(courseId, request.auth.uid))
        && get(enrollmentPath(courseId, request.auth.uid)).data.role == 'teacher';
    }

    function adminBootstrap(uid) {
      return signedIn()
        && request.auth.uid == uid
        && request.auth.token.email == 'innova506@hotmail.com'
        && !exists(profilePath(uid))
        && request.resource.data.id == uid
        && request.resource.data.email == 'innova506@hotmail.com'
        && request.resource.data.role == 'admin'
        && request.resource.data.disabled == false
        && request.resource.data.keys().hasOnly([
          'id', 'name', 'username', 'role', 'email', 'authProvider', 'disabled'
        ]);
    }

    match /userProfiles/{uid} {
      allow get: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow list: if isAdmin();
      allow create: if isAdmin() || adminBootstrap(uid);
      allow update, delete: if isAdmin();
    }

    // Los códigos son credenciales. Solo el administrador puede leerlos.
    match /studentCodes/{uid} {
      allow read, create, update, delete: if isAdmin();
    }

    match /courses/{courseId} {
      allow read: if isAdmin() || isCourseMember(courseId);
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || isTeacherFor(courseId);
    }

    match /enrollments/{enrollmentId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.sid == request.auth.uid)
        || isTeacherFor(resource.data.cid);
      allow create, update, delete: if isAdmin();
    }

    match /submissions/{submissionId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.sid == request.auth.uid)
        || isTeacherFor(resource.data.cid);

      allow create: if isStudent()
        && request.resource.data.sid == request.auth.uid
        && request.resource.data.id == submissionId
        && request.resource.data.type in ['quiz', 'assignment']
        && exists(enrollmentPath(request.resource.data.cid, request.auth.uid));

      allow update: if (isAdmin() || isTeacherFor(resource.data.cid))
        && request.resource.data.id == resource.data.id
        && request.resource.data.sid == resource.data.sid
        && request.resource.data.cid == resource.data.cid
        && request.resource.data.type == resource.data.type;

      allow delete: if isAdmin() || isTeacherFor(resource.data.cid);
    }

    match /views/{viewId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.sid == request.auth.uid)
        || isTeacherFor(resource.data.cid);

      allow create: if isStudent()
        && request.resource.data.sid == request.auth.uid
        && request.resource.data.id == viewId
        && exists(enrollmentPath(request.resource.data.cid, request.auth.uid));

      allow update: if false;
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if hasProfile();
      allow create, update, delete: if isAdmin();
    }

    // La estructura antigua queda cerrada de forma explícita.
    match /lms/{document=**} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
